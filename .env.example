VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Slice 7+ video provider. Phase 1 = "supabase" (Storage + MP4 progressive).
# Phase 2 will add "cloudflare" (Stream + HLS) — see docs/adr/0001-video-storage-supabase.md.
VITE_VIDEO_PROVIDER=supabase

# Phase 1: false — linear lessons only, no variation branches.
# Phase 2: set to true, then delete this flag and all references to it.
VITE_ALLOW_VARIATIONS=false

# PayOS sandbox credentials (PRD-0005).
# Set via: supabase secrets set PAYOS_CLIENT_ID=<value> ... against your dev project.
# Obtain from PayOS sandbox dashboard: https://business.payos.vn
#
# CHECKSUM_KEY: used by payos-webhook Edge Function to verify HMAC-SHA256
#   signature on the JSON body PayOS posts to us.
# CLIENT_ID + API_KEY: used by future slices when WE call PayOS API
#   (e.g. create payment link). PayOS does NOT send these as headers on
#   webhook callbacks — the body signature is the only auth.
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
